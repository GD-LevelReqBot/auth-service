# Required
SESSION_SECRET=change-this-to-a-long-random-string
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_REDIRECT_URI=https://gdlqbot.superdev.one/auth/twitch/callback

# Optional — YouTube Live Chat support
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://gdlqbot.superdev.one/auth/youtube/callback

# Port the auth service listens on (default: 3000)
PORT=3000

# Port the local desktop app listens on for the OAuth callback (default: 24363)
LOCAL_CLIENT_PORT=24363

# Set to 'production' to enable secure cookies
NODE_ENV=development
